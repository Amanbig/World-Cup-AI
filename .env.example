# football-data.org free API key
# Register at: https://www.football-data.org/client/register
# Free tier: 10 requests/minute, includes FIFA World Cup data
VITE_FOOTBALL_API_KEY=your_token_here

# Optional: override the base URL (leave blank to use default)
# VITE_FOOTBALL_API_BASE=https://api.football-data.org/v4

# Langflow (already configured in docker-compose.yml)
# VITE_LANGFLOW_BASE_URL=http://localhost:7860
# VITE_LANGFLOW_FLOW_ID=world-cup-analyst
